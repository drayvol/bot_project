# Telegram: токен бота — получить у @BotFather командой /newbot
BOT_TOKEN=your_bot_token

# Gemma: ключ Google AI Studio (aistudio.google.com) — OCR и верификация решений
GOOGLE_API_KEY=your_gemma_api_key

# Wolfram|Alpha AppID (опционально): эталонные корни для смешанных уравнений,
# без него их считает только sympy — точность чуть ниже
WOLFRAM_API_KEY=your_wolfram_appid

# Лимит запросов к Gemma в минуту, общий на все воркеры (опционально, по умолчанию 15)
# GEMINI_RPM=15
